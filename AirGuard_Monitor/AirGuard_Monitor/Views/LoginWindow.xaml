<Window
    x:Class="AirGuard.WPF.Views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AIRGUARD — 로그인"
    Height="480"
    Width="380"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="#0A0C0F"
    WindowStyle="None"
    AllowsTransparency="True">

    <Window.Resources>
        <Style
            TargetType="TextBlock">
            <Setter
                Property="Foreground"
                Value="#E8F4FF" />
            <Setter
                Property="FontFamily"
                Value="Consolas" />
        </Style>
        <Style
            TargetType="TextBox">
            <Setter
                Property="Background"
                Value="#0F1318" />
            <Setter
                Property="Foreground"
                Value="#00D4FF" />
            <Setter
                Property="BorderBrush"
                Value="#1E3A5F" />
            <Setter
                Property="BorderThickness"
                Value="1" />
            <Setter
                Property="FontFamily"
                Value="Consolas" />
            <Setter
                Property="FontSize"
                Value="13" />
            <Setter
                Property="Padding"
                Value="10,8" />
            <Setter
                Property="CaretBrush"
                Value="#00D4FF" />
        </Style>
        <Style
            TargetType="PasswordBox">
            <Setter
                Property="Background"
                Value="#0F1318" />
            <Setter
                Property="Foreground"
                Value="#00D4FF" />
            <Setter
                Property="BorderBrush"
                Value="#1E3A5F" />
            <Setter
                Property="BorderThickness"
                Value="1" />
            <Setter
                Property="FontFamily"
                Value="Consolas" />
            <Setter
                Property="FontSize"
                Value="13" />
            <Setter
                Property="Padding"
                Value="10,8" />
            <Setter
                Property="CaretBrush"
                Value="#00D4FF" />
        </Style>
    </Window.Resources>

    <Border
        BorderBrush="#1E3A5F"
        BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition
                    Height="40" />
                <RowDefinition
                    Height="*" />
            </Grid.RowDefinitions>

            <!-- 타이틀바 -->
            <Border
                Grid.Row="0"
                Background="#060810"
                MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid
                    Margin="12,0">
                    <StackPanel
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                        <Border
                            Width="18"
                            Height="18"
                            Background="#0D7FFF"
                            CornerRadius="2"
                            Margin="0,0,8,0">
                            <TextBlock
                                Text="▲"
                                FontSize="9"
                                FontWeight="Bold"
                                Foreground="White"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <TextBlock
                            Text="AIRGUARD"
                            FontSize="11"
                            FontWeight="Bold" />
                    </StackPanel>
                    <Button
                        Content="✕"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#3D5A73"
                        FontSize="13"
                        Cursor="Hand"
                        Click="CloseButton_Click" />
                </Grid>
            </Border>

            <!-- 로그인 폼 -->
            <StackPanel
                Grid.Row="1"
                Margin="40,30,40,40"
                VerticalAlignment="Center">

                <!-- 로고 -->
                <StackPanel
                    HorizontalAlignment="Center"
                    Margin="0,0,0,30">
                    <Border
                        Width="56"
                        Height="56"
                        Background="#0D7FFF"
                        CornerRadius="4"
                        HorizontalAlignment="Center">
                        <TextBlock
                            Text="▲"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="White"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <TextBlock
                        Text="AIRGUARD"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="#E8F4FF"
                        HorizontalAlignment="Center"
                        Margin="0,10,0,2" />
                    <TextBlock
                        Text="DRONE CONTROL SYSTEM"
                        FontSize="9"
                        Foreground="#3D5A73"
                        HorizontalAlignment="Center" />
                </StackPanel>

                <!-- 아이디 -->
                <TextBlock
                    Text="USERNAME"
                    FontSize="9"
                    Foreground="#3D5A73"
                    Margin="0,0,0,5" />
                <TextBox
                    x:Name="UsernameBox"
                    KeyDown="Input_KeyDown" />

                <!-- 비밀번호 -->
                <TextBlock
                    Text="PASSWORD"
                    FontSize="9"
                    Foreground="#3D5A73"
                    Margin="0,16,0,5" />
                <PasswordBox
                    x:Name="PasswordBox"
                    KeyDown="Input_KeyDown" />

                <!-- 오류 메시지 -->
                <TextBlock
                    x:Name="ErrorText"
                    Foreground="#FF3B3B"
                    FontSize="10"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0"
                    Visibility="Collapsed" />

                <!-- 로그인 버튼 -->
                <Button
                    x:Name="LoginButton"
                    Content="LOGIN"
                    Margin="0,24,0,0"
                    Height="42"
                    FontFamily="Consolas"
                    FontSize="13"
                    FontWeight="Bold"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="LoginButton_Click">
                    <Button.Background>
                        <SolidColorBrush
                            Color="#0D7FFF" />
                    </Button.Background>
                    <Button.Template>
                        <ControlTemplate
                            TargetType="Button">
                            <Border
                                Background="{TemplateBinding Background}"
                                CornerRadius="2">
                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger
                                    Property="IsMouseOver"
                                    Value="True">
                                    <Setter
                                        Property="Opacity"
                                        Value="0.85" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- 기본 계정 안내 -->
                <TextBlock
                    Text="기본 계정: admin / admin1234"
                    FontSize="9"
                    Foreground="#3D5A73"
                    HorizontalAlignment="Center"
                    Margin="0,14,0,0" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
